# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # ⚠️ NEVER expose to the client

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ─── Price API ────────────────────────────────────────────────────────────────
# Alpha Vantage — used by snapshotService.js to fetch daily OHLCV prices.
# Free tier: 25 requests/day, 5 requests/minute.
# Get a free key at: https://www.alphavantage.co/support/#api-key
# If left empty the snapshot service will skip live price fetches (use seed data only).
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# ─── Snapshot service ─────────────────────────────────────────────────────────
# Delay in ms between Alpha Vantage requests (free tier: 5 req/min → 12 000 ms safe).
# Set to 0 in dev/test when using mock data or a paid API key.
SNAPSHOT_RATE_DELAY_MS=12000

# ─── Banxico BMX API ──────────────────────────────────────────────────────────
# Used to fetch live "Tasa de Interés" for Bonos Gubernamentales (CETES, BONDIA, etc.)
# Generate a token at: https://www.banxico.org.mx/SieAPIRest/service/v1/token
BANXICO_BMX_TOKEN=your-banxico-bmx-token-here

# ─── Database seed ────────────────────────────────────────────────────────────
# Target Supabase user UUID for `npm run seed`.
# Find your UUID in Supabase Dashboard → Authentication → Users.
SEED_USER_ID=your-supabase-user-uuid-here
